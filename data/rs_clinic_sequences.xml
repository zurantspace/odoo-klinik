<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════
         Sequences
    ═════════════════════════════════════════════════ -->

    <!-- No. Rekam Medis: RM/2025/00001 -->
    <record id="seq_rs_patient" model="ir.sequence">
        <field name="name">Nomor Rekam Medis Pasien</field>
        <field name="code">rs.patient.sequence</field>
        <field name="prefix">RM/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">False</field>
    </record>

    <!-- No. Kunjungan: VIS/2025/00001 -->
    <record id="seq_rs_clinic_visit" model="ir.sequence">
        <field name="name">Nomor Kunjungan Pasien</field>
        <field name="code">rs.clinic.visit.sequence</field>
        <field name="prefix">VIS/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">False</field>
    </record>
</odoo>
