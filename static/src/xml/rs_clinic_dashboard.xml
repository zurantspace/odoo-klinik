<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="rs_clinic.Dashboard" owl="1">
    <div class="o_rs_clinic_dashboard d-flex flex-column h-100 bg-light">

        <!-- ── Native-Style Control Panel Header ─── -->
        <div class="o_control_panel d-flex align-items-center justify-content-between px-4 py-3 border-bottom bg-white shadow-sm flex-shrink-0">
            <div class="o_cp_left">
                <span class="fs-5 fw-bold text-dark">Ringkasan Klinik</span>
            </div>
            <div class="o_cp_right d-flex align-items-center gap-3">
                <span class="text-muted small">
                    <i class="fa fa-calendar me-1"/>
                    <t t-esc="state.todayStr"/>
                </span>
                <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1" t-on-click="refreshData">
                    <i t-att-class="state.isLoading ? 'fa fa-spin fa-refresh' : 'fa fa-refresh'"/>
                    <span>Segarkan</span>
                </button>
            </div>
        </div>

        <!-- ── Main Scrollable Content ─── -->
        <div class="o_content flex-grow-1 overflow-auto p-4">

            <!-- ── KPI Stat Row (Consistent Odoo-Style Cards) ─── -->
            <div class="row g-3 mb-4">
                
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #00A09D !important; cursor: pointer;"
                         t-on-click="() => this.openAction('rs_clinic.action_rs_clinic_visit_today')">
                        <div class="card-body d-flex align-items-center justify-content-between p-3">
                            <div>
                                <span class="text-muted small d-block mb-1">Kunjungan Hari Ini</span>
                                <span class="fs-3 fw-bold text-dark">
                                    <t t-if="state.isLoading">—</t>
                                    <t t-else=""><t t-esc="state.visitTodayCount"/></t>
                                </span>
                            </div>
                            <div class="bg-light rounded p-2 text-muted" style="background-color: rgba(0, 160, 157, 0.1) !important; color: #00A09D !important;">
                                <i class="fa fa-users fa-2x"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #E9A115 !important; cursor: pointer;"
                         t-on-click="() => this.openAction('rs_clinic.action_rs_clinic_visit_today')">
                        <div class="card-body d-flex align-items-center justify-content-between p-3">
                            <div>
                                <span class="text-muted small d-block mb-1">Menunggu Antrian</span>
                                <span class="fs-3 fw-bold text-dark">
                                    <t t-if="state.isLoading">—</t>
                                    <t t-else=""><t t-esc="state.queueCount"/></t>
                                </span>
                            </div>
                            <div class="bg-light rounded p-2 text-muted" style="background-color: rgba(233, 161, 21, 0.1) !important; color: #E9A115 !important;">
                                <i class="fa fa-clock-o fa-2x"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #243746 !important; cursor: pointer;"
                         t-on-click="() => this.openAction('rs_clinic.action_rs_clinic_visit_today')">
                        <div class="card-body d-flex align-items-center justify-content-between p-3">
                            <div>
                                <span class="text-muted small d-block mb-1">Sedang Ditangani</span>
                                <span class="fs-3 fw-bold text-dark">
                                    <t t-if="state.isLoading">—</t>
                                    <t t-else=""><t t-esc="state.inProgressCount"/></t>
                                </span>
                            </div>
                            <div class="bg-light rounded p-2 text-muted" style="background-color: rgba(36, 55, 70, 0.1) !important; color: #243746 !important;">
                                <i class="fa fa-stethoscope fa-2x"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #22c55e !important; cursor: pointer;"
                         t-on-click="() => this.openAction('rs_clinic.action_rs_patient')">
                        <div class="card-body d-flex align-items-center justify-content-between p-3">
                            <div>
                                <span class="text-muted small d-block mb-1">Total Pasien Terdaftar</span>
                                <span class="fs-3 fw-bold text-dark">
                                    <t t-if="state.isLoading">—</t>
                                    <t t-else=""><t t-esc="state.patientCount"/></t>
                                </span>
                            </div>
                            <div class="bg-light rounded p-2 text-muted" style="background-color: rgba(34, 197, 94, 0.1) !important; color: #22c55e !important;">
                                <i class="fa fa-id-card fa-2x"/>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── Pasien Sedang Ditangani (Real-Time Live Feed) ─── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <span class="fw-bold text-dark"><i class="fa fa-stethoscope me-2 text-primary"/>Pasien Sedang Ditangani</span>
                </div>
                <div class="card-body p-0">
                    <t t-if="state.isLoading">
                        <div class="text-center text-muted py-4">
                            <i class="fa fa-circle-o-notch fa-spin me-2"/>
                            <span>Memuat data kunjungan aktif...</span>
                        </div>
                    </t>
                    <t t-elif="state.activeVisits.length === 0">
                        <div class="text-center text-muted py-4">
                            <i class="fa fa-info-circle me-1"/>
                            <span>Tidak ada pasien yang sedang ditangani saat ini.</span>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3" style="width: 80px;">No.</th>
                                        <th>Pasien</th>
                                        <th>Poliklinik</th>
                                        <th>Dokter</th>
                                        <th>Pembayaran</th>
                                        <th class="text-end pe-3" style="width: 100px;">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.activeVisits" t-as="visit" t-key="visit.id">
                                        <tr>
                                            <td class="ps-3 fw-bold text-primary"><t t-esc="visit.queue_number"/></td>
                                            <td>
                                                <div class="fw-semibold"><t t-esc="visit.patient_id[1]"/></div>
                                                <div class="text-muted small"><t t-esc="visit.reference"/></div>
                                            </td>
                                            <td><t t-esc="visit.polyclinic_id[1]"/></td>
                                            <td>
                                                <t t-if="visit.doctor_id">
                                                    <t t-esc="visit.doctor_id[1]"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted small italic">- Belum dipilih -</span>
                                                </t>
                                            </td>
                                            <td>
                                                <span t-if="visit.insurance_type == 'bpjs'" class="badge text-bg-success">BPJS</span>
                                                <span t-elif="visit.insurance_type == 'private'" class="badge text-bg-info text-white">Asuransi</span>
                                                <span t-else="" class="badge text-bg-secondary">Umum</span>
                                            </td>
                                            <td class="text-end pe-3">
                                                <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.openVisitDetail(visit.id)">
                                                    Buka
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </div>

            <!-- ── Kolom 2: Aksi Cepat + Status Poli ─── -->
            <div class="row g-4">
                
                <!-- Aksi Cepat -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-0 py-3">
                            <span class="fw-bold text-dark"><i class="fa fa-bolt me-2 text-warning"/>Aksi Cepat</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                
                                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 border-0"
                                    t-on-click="() => this.openAction('rs_clinic.action_rs_clinic_visit_today')">
                                    <div class="bg-light rounded p-2 text-primary" style="background-color: rgba(0, 160, 157, 0.1) !important; color: #00A09D !important;">
                                        <i class="fa fa-list-ol fa-fw"/>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark small">Panggil &amp; Antrian Hari Ini</div>
                                        <div class="text-muted small" style="font-size:0.75rem">Kelola antrian pasien aktif per poliklinik</div>
                                    </div>
                                    <i class="fa fa-chevron-right ms-auto text-muted small"/>
                                </button>

                                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 border-0"
                                    t-on-click="() => this.openNewVisit()">
                                    <div class="bg-light rounded p-2 text-success" style="background-color: rgba(34, 197, 94, 0.1) !important; color: #22c55e !important;">
                                        <i class="fa fa-plus fa-fw"/>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark small">Daftarkan Kunjungan Baru</div>
                                        <div class="text-muted small" style="font-size:0.75rem">Daftarkan pasien ke poliklinik tujuan</div>
                                    </div>
                                    <i class="fa fa-chevron-right ms-auto text-muted small"/>
                                </button>

                                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 border-0"
                                    t-on-click="() => this.openAction('rs_clinic.action_rs_patient')">
                                    <div class="bg-light rounded p-2 text-info" style="background-color: rgba(13, 202, 240, 0.1) !important; color: #0dcaf0 !important;">
                                        <i class="fa fa-search fa-fw"/>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark small">Cari / Tambah Pasien</div>
                                        <div class="text-muted small" style="font-size:0.75rem">Master data Rekam Medis pasien</div>
                                    </div>
                                    <i class="fa fa-chevron-right ms-auto text-muted small"/>
                                </button>

                                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 border-0"
                                    t-on-click="() => this.openAction('rs_clinic.action_rs_clinic_visit')">
                                    <div class="bg-light rounded p-2 text-secondary" style="background-color: rgba(108, 117, 125, 0.1) !important; color: #6c757d !important;">
                                        <i class="fa fa-history fa-fw"/>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark small">Semua Riwayat Kunjungan</div>
                                        <div class="text-muted small" style="font-size:0.75rem">Seluruh daftar transaksi kunjungan klinik</div>
                                    </div>
                                    <i class="fa fa-chevron-right ms-auto text-muted small"/>
                                </button>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Poliklinik -->
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-0 py-3">
                            <span class="fw-bold text-dark"><i class="fa fa-hospital-o me-2 text-info"/>Status Poliklinik Aktif</span>
                        </div>
                        <div class="card-body p-0">
                            <t t-if="state.isLoading">
                                <div class="text-center text-muted py-4">
                                    <i class="fa fa-circle-o-notch fa-spin me-2"/>
                                    <span>Memuat poliklinik...</span>
                                </div>
                            </t>
                            <t t-elif="state.polyclinics.length === 0">
                                <div class="text-center text-muted py-4">
                                    <span>Tidak ada poliklinik aktif.</span>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="ps-3">Nama Poliklinik</th>
                                                <th class="text-center" style="width: 120px;">Total Hari Ini</th>
                                                <th class="text-center" style="width: 120px;">Antrian Aktif</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.polyclinics" t-as="poli" t-key="poli.id">
                                                <tr style="cursor: pointer;" t-on-click="() => this.openAction('rs_clinic.action_rs_clinic_visit_today')">
                                                    <td class="ps-3 fw-semibold"><t t-esc="poli.name"/></td>
                                                    <td class="text-center">
                                                        <span t-att-class="poli.visit_today_count > 0 ? 'badge rounded-pill text-bg-primary' : 'badge rounded-pill text-bg-light text-muted'">
                                                            <t t-esc="poli.visit_today_count"/>
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <span t-att-class="poli.queue_today_count > 0 ? 'badge rounded-pill text-bg-warning' : 'badge rounded-pill text-bg-light text-muted'">
                                                            <t t-esc="poli.queue_today_count"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>
</t>

</templates>
