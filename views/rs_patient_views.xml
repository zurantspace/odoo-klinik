<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════
         rs.patient — Pasien Views
    ════════════════════════════════════════════════════════════ -->

    <!-- LIST VIEW -->
    <record id="view_rs_patient_list" model="ir.ui.view">
        <field name="name">rs.patient.list</field>
        <field name="model">rs.patient</field>
        <field name="arch" type="xml">
            <list string="Daftar Pasien" decoration-warning="is_minor == True">
                <field name="patient_no" optional="show"/>
                <field name="name"/>
                <field name="nik" optional="show"/>
                <field name="age" string="Umur"/>
                <field name="gender"/>
                <field name="insurance_type" widget="badge"
                    decoration-success="insurance_type == 'bpjs'"
                    decoration-info="insurance_type == 'private'"
                    decoration-muted="insurance_type == 'general'"/>
                <field name="phone"/>
                <field name="last_visit_date" optional="show"/>
                <field name="visit_count" optional="show"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_rs_patient_form" model="ir.ui.view">
        <field name="name">rs.patient.form</field>
        <field name="model">rs.patient</field>
        <field name="arch" type="xml">
            <form string="Data Pasien">
                <header>
                    <button name="action_register_visit"
                        string="Daftar Kunjungan Baru"
                        type="object"
                        class="btn-primary"
                        icon="fa-calendar-plus-o"/>
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                            type="object"
                            name="action_view_visits"
                            icon="fa-stethoscope">
                            <field name="visit_count" widget="statinfo" string="Kunjungan"/>
                        </button>
                    </div>

                    <!-- Header Pasien -->
                    <div class="oe_title">
                        <label for="name" string="Nama Lengkap"/>
                        <h1>
                            <field name="name" placeholder="Nama lengkap pasien..."/>
                        </h1>
                        <div class="o_row">
                            <field name="patient_no" class="o_field_widget o_stat_info"/>
                        </div>
                    </div>

                    <!-- Identitas Utama -->
                    <group string="Identitas">
                        <group>
                            <field name="nik" placeholder="16 digit NIK KTP"/>
                            <field name="birth_date"/>
                            <field name="age" readonly="1"/>
                            <field name="gender"/>
                            <field name="blood_type"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address" placeholder="Alamat lengkap..."/>
                        </group>
                    </group>

                    <!-- Informasi Asuransi -->
                    <group string="Informasi Pembayaran">
                        <group>
                            <field name="insurance_type" widget="radio"/>
                        </group>
                        <group>
                            <field name="bpjs_no"
                                invisible="insurance_type != 'bpjs'"
                                placeholder="13 digit nomor BPJS"/>
                            <field name="bpjs_class"
                                invisible="insurance_type != 'bpjs'"/>
                            <field name="insurance_company"
                                invisible="insurance_type != 'private'"/>
                            <field name="insurance_no"
                                invisible="insurance_type != 'private'"/>
                        </group>
                    </group>

                    <!-- Notebook -->
                    <notebook>
                        <page string="Informasi Medis" name="medical_info">
                            <group>
                                <group>
                                    <field name="allergy_notes"
                                        placeholder="Alergi obat / makanan / bahan lain..."/>
                                    <field name="chronic_disease"
                                        placeholder="Penyakit kronis yang diderita..."/>
                                </group>
                            </group>
                        </page>

                        <page string="Kontak Darurat &amp; Wali" name="emergency">
                            <group>
                                <group string="Kontak Darurat">
                                    <field name="emergency_contact_name"/>
                                    <field name="emergency_contact_phone"/>
                                    <field name="emergency_contact_relation"/>
                                </group>
                                <group string="Wali (Pasien Anak)" invisible="is_minor == False">
                                    <field name="is_minor" readonly="1" invisible="1"/>
                                    <field name="guardian_name"/>
                                    <field name="guardian_relation"/>
                                </group>
                            </group>
                        </page>

                        <page string="Riwayat Kunjungan" name="visit_history">
                            <field name="visit_ids" readonly="1">
                                <list>
                                    <field name="reference"/>
                                    <field name="visit_date"/>
                                    <field name="polyclinic_id"/>
                                    <field name="doctor_id"/>
                                    <field name="visit_type"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'done'"
                                        decoration-warning="state == 'in_progress'"
                                        decoration-info="state == 'queued'"
                                        decoration-danger="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_rs_patient_search" model="ir.ui.view">
        <field name="name">rs.patient.search</field>
        <field name="model">rs.patient</field>
        <field name="arch" type="xml">
            <search string="Cari Pasien">
                <field name="name" string="Nama / No. RM"
                    filter_domain="['|', ('name', 'ilike', self), ('patient_no', 'ilike', self)]"/>
                <field name="nik"/>
                <field name="bpjs_no"/>
                <field name="phone"/>
                <separator/>
                <filter string="BPJS" name="filter_bpjs"
                    domain="[('insurance_type', '=', 'bpjs')]"/>
                <filter string="Pasien Umum" name="filter_general"
                    domain="[('insurance_type', '=', 'general')]"/>
                <filter string="Pasien Anak" name="filter_minor"
                    domain="[('is_minor', '=', True)]"/>
                <group>
                    <filter name="group_insurance" string="Jenis Pembayaran"
                        context="{'group_by': 'insurance_type'}"/>
                    <filter name="group_gender" string="Jenis Kelamin"
                        context="{'group_by': 'gender'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_rs_patient" model="ir.actions.act_window">
        <field name="name">Data Pasien</field>
        <field name="res_model">rs.patient</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_rs_patient_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada data pasien terdaftar.
            </p>
            <p>Klik <b>Baru</b> untuk mendaftarkan pasien pertama.</p>
        </field>
    </record>
</odoo>
